{
  "name": "qastack",
  "version": "0.1.0",
  "description": "Full QA stack in a box — from user stories to green light",
  "type": "module",
  "bin": {
    "qastack": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hafizrazali/qastack"
  },
  "keywords": ["qa", "testing", "playwright", "dashboard", "ai", "test-generation"],
  "author": "Hafiz Razali",
  "license": "MIT",
  "homepage": "https://github.com/hafizrazali/qastack#readme",
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@qastack/core": "workspace:*",
    "@qastack/collector": "workspace:*",
    "@qastack/analyzer": "workspace:*",
    "@qastack/api": "workspace:*",
    "@qastack/discovery": "workspace:*",
    "@qastack/generator": "workspace:*",
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.0",
    "@inquirer/prompts": "^7.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "vitest": "^3.0.0",
    "typescript": "^5.7.0",
    "tsx": "^4.0.0",
    "better-sqlite3": "^11.0.0",
    "@types/better-sqlite3": "^7.0.0"
  }
}
